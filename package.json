{
  "name": "@remato/personal-code-to-birthday",
  "version": "1.2.2",
  "description": "Converts personal identification codes from various countries into birthdate",
  "license": "MIT",
  "main": "src/index.ts",
  "repository": {
    "url": "https://github.com/rematocorp/personal-code-to-birthday"
  },
  "scripts": {
