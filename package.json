    "lint": "oxlint",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@remato/prettier-config": "^1.1.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "oxlint": "^1.60.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "prettier": "@remato/prettier-config"
