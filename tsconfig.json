{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"outDir": "./demo",
		"target": "ES2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"sourceMap": true,
		"noImplicitAny": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"newLine": "lf"
	},
	"exclude": ["./node_modules"]
}
